# Default explorer settings.
# These define the initial values shown to users before any customization.
# Users can still override all of these in the Settings panel.

# Default consensus contract address.
# VITE_DEFAULT_CONSENSUS=0x223624cBF099e5a8f8cD5aF22aFa424a1d1acEE9

# Default RPC endpoint URL.
# VITE_DEFAULT_RPC=https://1rpc.io/gnosis

# Default calldata decoder URL (must include the calldata query parameter).
# VITE_DEFAULT_DECODER=https://calldata.swiss-knife.xyz/decoder?calldata=

# Default relayer URL. When set, transaction proposal submission is enabled by default.
# VITE_DEFAULT_RELAYER=

# Default max block range for log queries.
# VITE_DEFAULT_MAX_BLOCK_RANGE=10000

# Default validator info JSON URL.
# VITE_DEFAULT_VALIDATOR_INFO=https://raw.githubusercontent.com/safe-fndn/safenet-beta-data/refs/heads/main/assets/validator-info.json

# Default UI refetch interval in milliseconds (0 to disable automatic refetching).
# VITE_DEFAULT_REFETCH_INTERVAL=10000

# Default blocks per epoch.
# VITE_DEFAULT_BLOCKS_PER_EPOCH=1440

# Default signing timeout in blocks.
# VITE_DEFAULT_SIGNING_TIMEOUT=12

# Base path when the app is served from a sub-path (e.g. /explorer/).
# VITE_BASE_PATH=/

# URL for the "Docs" link in the footer.
# VITE_DOCS_URL=https://docs.safefoundation.org/safenet

# URL for the "Terms" link in the footer.
# VITE_TERMS_URL=

# URL for the "Privacy" link in the footer.
# VITE_PRIVACY_URL=

# URL for the "Imprint" link in the footer.
# VITE_IMPRINT_URL=

# Plausible site domain (e.g. explorer.safenet.io).
# When set, Plausible tracking is initialized. When unset, no analytics run.
# VITE_PLAUSIBLE_DOMAIN=

# Full URL of the Plausible API endpoint.
# Override for self-hosted Plausible instances.
# VITE_PLAUSIBLE_ENDPOINT=https://plausible.io/api/event

# IPFS deployment via Pinata (used by `npm run deploy:ipfs`).
# Get a JWT at https://app.pinata.cloud/developers/api-keys
# PINATA_JWT=
# Your dedicated gateway domain (e.g. my-gateway.mypinata.cloud). Optional.
# PINATA_GATEWAY=
