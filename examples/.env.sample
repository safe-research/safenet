# ============================================================
# Safenet Examples — Environment Configuration
# ============================================================
# Copy this file to examples/.env and fill in the values.

# RPC endpoints
GNOSIS_RPC_URL=https://rpc.gnosischain.com

# Safenet Consensus contract on Gnosis Chain (chain ID 100)
CONSENSUS_ADDRESS=0x223624cBF099e5a8f8cD5aF22aFa424a1d1acEE9

# Safe Transaction Service (Sepolia)
SAFE_TX_SERVICE_URL=https://api.safe.global/tx-service/sep
SAFE_TX_SERVICE_API_KEY=
