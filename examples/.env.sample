# ============================================================
# Cosigner + Hypernative Guard Integration Test (Sepolia)
# ============================================================
# Copy this file to examples/.env and fill in the values.
# Run with: npm run test:integration:cosigner

# RPC endpoints
SEPOLIA_RPC_URL=https://sepolia.drpc.org
GNOSIS_RPC_URL=https://rpc.gnosischain.com

# Safenet Consensus contract on Gnosis Chain (chain ID 100)
CONSENSUS_ADDRESS=0x223624cBF099e5a8f8cD5aF22aFa424a1d1acEE9

# Safe Transaction Service
SAFE_TX_SERVICE_URL=https://api.safe.global/tx-service/sep
SAFE_TX_SERVICE_API_KEY=

# Forge keystore aliases
OWNER1_ACCOUNT=owner1
OWNER2_ACCOUNT=owner2
KEEPER_ACCOUNT=keeper
DEPLOYER_ACCOUNT=deployer

# EOA addresses corresponding to keystore aliases above
OWNER1_ADDRESS=
OWNER2_ADDRESS=
KEEPER_ADDRESS=
DEPLOYER_ADDRESS=

# Optional overrides (defaults shown)
# CONSENSUS_CHAIN_ID=100          # Gnosis Chain
# ALLOW_TX_DELAY=60               # seconds
# COSIGNER_SALT=0x000...0         # bytes32 salt for SafenetCosigner CREATE2
# GUARD_SALT=0x000...0            # bytes32 salt for HypernativeGuard CREATE2
# SAFE_CREATION_SALT_NONCE=0      # nonce for Safe proxy CREATE2

# Attestation poll timeout in seconds (default: 120)
ATTESTATION_TIMEOUT_SECONDS=120
