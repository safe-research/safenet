// Separate devcontainer file for MacOS.
// The one in ../devcontainer.json is specific to Linux/Fedora and some args don't work.
// Devcontainers don't support `extends` yet, hence we need to keep them in sync manually.

{
  "name": "Safenet (MacOS)",
  "image": "mcr.microsoft.com/devcontainers/typescript-node:dev-24-bookworm",

  // User that VS Code connects as *inside* the container.
  "remoteUser": "node",

  // Use the following 1pw integration if you need 1pw secrets in your container.
  "features": {
    "ghcr.io/flexwie/devcontainer-features/op:1": {}
  },
  "remoteEnv": {
    // Needs export OP_SERVICE_ACCOUNT_TOKEN env var on the host.
    // Get a service account token via https://developer.1password.com/docs/service-accounts/
    // You can then use the pk via "$(op read 'op://VAULT/ITEM/FIELD')"
    "OP_SERVICE_ACCOUNT_TOKEN": "${localEnv:OP_SERVICE_ACCOUNT_TOKEN}"
  }
}
